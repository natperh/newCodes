graph TD
  subgraph "Business Process Model"
    Start --> InputData
    InputData --> Validate
    Validate --> Error en datos
    Error en datos --> Terminar
    Validate --> ProcesarReglas
    ProcesarReglas --> EscribirResultados
    EscribirResultados --> Terminar

    class InputData {
        Lectura de dos números enteros
    }
    class Validate {
        Verificar que los datos sean válidos
    }
    class ProcesarReglas {
        Suma de dos números
    }
    class EscribirResultados {
        Mostrar resultado en pantalla
    }
  end