graph TD
  subgraph "Business Process Model"
    Start --> InputData
    InputData --> Validate
    Validate --> Error en caso de fallo
    Validate --> BusinessLogic en caso de éxito
    BusinessLogic --> OutputData
    OutputData --> End
  end
  
  subgraph "Código COBOL"
  InputData((Lectura de Datos)) --> MainProgram
  MainProgram --> AskUser
  AskUser --> Get3Numbers
  Get3Numbers --> AddNumbers
  AddNumbers --> DisplayResult
  end
  
  InputData --> ValidateRules
  ValidateRules --> BusinessLogic
  BusinessLogic --> WriteOutput
  WriteOutput --> EndProcess