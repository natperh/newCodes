graph TD
  subgraph "API Rest"
    id1(API Rest) -->|suma| id2(Controlador.suma)
    click id1 "/suma"
  end

  subgraph "Business Process Model (BPM)"
    Start((Inicio)) --> Input[Obtener Datos Usuario]
    Input --> Logic[Validar Entrada]
    Logic -- "num1, num2 válidos" --> id2
    Logic -- "Fallo" --> Error((Fin con Error))
    id2 --> Output[Responder Resultado]
    Output --> End((Fin Proceso))
  end